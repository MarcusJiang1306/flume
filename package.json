{
  "name": "@soulglad/flume",
  "version": "0.0.1",
  "type": "module",
  "description": "可视化图形编辑工具，支持拖拽节点、连接线条，实时生成 Mermaid 代码",
  "author": "Marcus Jiang",
  "license": "MIT",
  "main": "./dist/flume.cjs.js",
  "module": "./dist/flume.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/flume.es.js",
      "require": "./dist/flume.cjs.js"
    },
    "./style.css": "./dist/flume.css"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "vue",
    "flowchart",
    "diagram",
    "mermaid",
    "graph",
    "node-editor",
    "visualization",
    "canvas"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "dagre": "^0.8.5"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.9.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue": "^3.5.29",
    "vue-tsc": "^3.1.5"
  }
}
